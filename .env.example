# Public URL of the FastAPI server (server/) — typically a cloudflared/ngrok tunnel
# pointing at the GPU box that runs SAM 2 + PANDORA.
#
# Get this URL by running `bash server/run.sh` on the GPU box and copying the
# cloudflared output (looks like https://xxx-yyy-zzz.trycloudflare.com).
VITE_API_BASE="https://your-tunnel.trycloudflare.com"
