# Copy this file to server/.env on the GPU box. Anything set here is
# automatically loaded by server/run.sh before defaults are applied.
# server/.env is git-ignored, so each box can keep its own paths.

# Path to the existing pandora-removal_demo/ directory (the one from
# Object_Removal_benchmark_v21). run.sh searches common locations if this
# is unset; set it explicitly if your layout differs.
# PANDORA_DEMO_DIR=/raid/hvtham/nvloc/Object_Removal_benchmark_v21/pandora-removal_demo

# Override PANDORA's diffusion model. Defaults to sd2-community/stable-diffusion-2-1
# (verbatim mirror of the deprecated stabilityai/stable-diffusion-2-1).
# Can be a HF repo id or a local directory.
# PANDORA_MODEL_PATH=sd2-community/stable-diffusion-2-1

# Port for uvicorn. Defaults to an auto-picked free port (recommended on
# shared GPU boxes).
# PORT=8765

# Optional: skip preloading PANDORA at startup to make uvicorn boot faster.
# Inpaint requests will load it lazily on first call instead.
# PRELOAD_PANDORA=0

# Cloudflared transport. Default is "http2" (TCP/443) because most lab/uni
# firewalls block outbound UDP. Set to "quic" only if you've confirmed UDP
# egress works on the box.
# CLOUDFLARED_PROTOCOL=http2

# Force IPv4 to Cloudflare edge. Set to 6 if your box has working IPv6
# routing and you'd rather use it.
# CLOUDFLARED_EDGE_IP_VERSION=4
